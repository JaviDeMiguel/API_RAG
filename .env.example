# Copia este archivo como `.env` y rellena tus valores.

# --- Anthropic / Claude ---
# Clave de la API de Anthropic (Claude). Obligatoria para responder preguntas.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo a utilizar. Por defecto usamos el Opus más capaz.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Base de datos ---
# Ruta del archivo SQLite. Usa ":memory:" para una BD efímera en memoria.
DB_PATH=data/app.db

# --- Autenticación (JWT) ---
# Secreto para firmar los tokens. ¡CÁMBIALO en producción por un valor aleatorio!
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Fragmentación (chunking) ---
CHUNK_SIZE=180
CHUNK_OVERLAP=40

# --- Recuperación (retrieval por embeddings) ---
# Número de fragmentos relevantes que se recuperan por pregunta.
TOP_K=4
# Dimensión del vector de embedding (proveedor local).
EMBEDDING_DIM=512
