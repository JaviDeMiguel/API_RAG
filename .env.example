# Copia este archivo como `.env` y rellena tus valores.

# --- Anthropic / Claude ---
# Clave de la API de Anthropic (Claude). Obligatoria para responder preguntas.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo a utilizar. Por defecto usamos el Opus más capaz.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Base de datos ---
# Ruta del archivo SQLite (usuarios y metadatos de documentos).
# Usa ":memory:" para una BD efímera en memoria.
DB_PATH=data/app.db

# --- Base de datos vectorial (ChromaDB) ---
# Directorio de persistencia de Chroma (fragmentos + embeddings + índice).
# Usa ":memory:" para una instancia efímera en memoria.
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=chunks

# --- Autenticación (JWT) ---
# Secreto para firmar los tokens. ¡CÁMBIALO en producción por un valor aleatorio!
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Fragmentación (chunking) ---
CHUNK_SIZE=180
CHUNK_OVERLAP=40

# --- Recuperación (retrieval por embeddings) ---
# Número de fragmentos relevantes que se recuperan por pregunta.
TOP_K=4

# Proveedor de embeddings: "local" (por defecto, sin claves ni red) o "voyage"
# (embeddings semánticos de Voyage AI; requiere clave y el paquete voyageai).
EMBEDDING_PROVIDER=local
# Dimensión del vector de embedding (proveedor local).
EMBEDDING_DIM=512

# --- Voyage AI (solo si EMBEDDING_PROVIDER=voyage) ---
# VOYAGE_API_KEY=pa-...
# VOYAGE_MODEL=voyage-3.5
# Dimensión de salida (voyage-3.5 admite 256/512/1024/2048). Vacío = por defecto.
# VOYAGE_EMBEDDING_DIM=1024
